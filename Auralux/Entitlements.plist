<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- App Sandbox (required for Mac App Store) -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- File access: user-chosen files via open/save panels and drag-and-drop -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- Network: outgoing connections to local inference server -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Network: local inference server listens on loopback -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- Audio input: needed for future audio-to-audio recording features -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
